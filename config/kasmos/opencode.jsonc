{
    "plugin": [
        "@franlol/opencode-md-table-formatter@latest"
    ],
    "agent": {
        "planner": {
            "model": "anthropic/claude-opus-4-6",
            "temperature": 0.3,
            "reasoningEffort": "max",
            "textVerbosity": "medium",
            "permission": {
                "read": "allow",
                "write": "allow",
                "edit": "allow",
                "glob": "allow",
                "grep": "allow",
                "bash": "allow",
                "external_directory": {
                    "/tmp/*": "allow",
                    "/tmp/**": "allow",
                    "~/.config/zellij/*": "allow",
                    "~/.config/zellij/**": "allow",
                    "~/.config/opencode/*": "allow",
                    "~/.config/opencode/**": "allow",
                    "~/dev/kasmos/*": "allow",
                    "~/dev/kasmos/**": "allow",
                    ".kasmos/*": "allow",
                    "*": "ask"
                }
            }
        },
        "manager": {
            "model": "anthropic/claude-opus-4-6",
            "temperature": 0.2,
            "reasoningEffort": "high",
            "textVerbosity": "medium",
            "permission": {
                "read": "allow",
                "write": "allow",
                "edit": "allow",
                "glob": "allow",
                "grep": "allow",
                "bash": "allow",
                "external_directory": {
                    "/tmp/*": "allow",
                    "/tmp/**": "allow",
                    "~/.config/zellij/*": "allow",
                    "~/.config/zellij/**": "allow",
                    "~/.config/opencode/*": "allow",
                    "~/.config/opencode/**": "allow",
                    "~/dev/kasmos/*": "allow",
                    "~/dev/kasmos/**": "allow",
                    ".kasmos/*": "allow",
                    "*": "ask"
                }
            }
        },
        "coder": {
            "model": "openai/gpt-5.3-codex",
            "temperature": 0.1,
            "reasoningEffort": "medium",
            "textVerbosity": "low",
            "permission": {
                "read": "allow",
                "write": "allow",
                "edit": "allow",
                "glob": "allow",
                "grep": "allow",
                "bash": "allow",
                "external_directory": {
                    "/tmp/*": "allow",
                    "/tmp/**": "allow",
                    "~/dev/kasmos/*": "allow",
                    "~/dev/kasmos/**": "allow",
                    "~/.config/zellij/*": "allow",
                    "~/.config/zellij/**": "allow",
                    "~/.config/opencode/*": "allow",
                    "~/.config/opencode/**": "allow",
                    "*": "ask"
                }
            }
        },
        "reviewer": {
            "model": "anthropic/claude-sonnet-4-6",
            "temperature": 0.2,
            "reasoningEffort": "high",
            "textVerbosity": "medium",
            "permission": {
                "read": "allow",
                "glob": "allow",
                "grep": "allow",
                "bash": "allow",
                "edit": {
                    "/tmp/*": "allow",
                    "/tmp/**": "allow",
                    "*": "deny"
                },
                "write": {
                    "/tmp/*": "allow",
                    "/tmp/**": "allow",
                    "*": "deny"
                },
                "external_directory": {
                    "/tmp/*": "allow",
                    "/tmp/**": "allow",
                    "~/dev/kasmos/*": "allow",
                    "*": "ask"
                }
            }
        },
        "release": {
            "model": "openai/gpt-5.3-codex",
            "temperature": 0.1,
            "reasoningEffort": "high",
            "textVerbosity": "medium",
            "permission": {
                "read": "allow",
                "write": "allow",
                "edit": "allow",
                "glob": "allow",
                "grep": "allow",
                "bash": "allow",
                "external_directory": {
                    "/tmp/*": "allow",
                    "/tmp/**": "allow",
                    "~/dev/kasmos/*": "allow",
                    "~/dev/kasmos/**": "allow",
                    "~/.config/zellij/*": "allow",
                    "~/.config/zellij/**": "allow",
                    "~/.config/opencode/*": "allow",
                    "~/.config/opencode/**": "allow",
                    "*": "ask"
                }
            }
        }
    },
    "mcp": {
        "zellij": {
            "type": "local",
            "command": [
                "bun",
                "run",
                "/opt/zellij-pane-tracker/mcp-server/index.ts"
            ],
            "enabled": true
        },
        "kasmos": {
            "command": [
                "kasmos",
                "serve"
            ],
            "type": "local",
            "enabled": true
        }
    }
}
