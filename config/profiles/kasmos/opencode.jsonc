{
  // OpenCode profile template for kasmos orchestrated agents.
  // Generated by `kasmos setup` as a baseline reference.
  // The actual MCP config is delivered via .opencode/opencode.jsonc (project-level).
  "mcpServers": {
    "kasmos": {
      "command": "kasmos",
      "args": ["serve"],
      "type": "stdio"
    },
    "zellij-pane-tracker": {
      "command": "zellij-pane-tracker",
      "args": [],
      "type": "stdio"
    }
  }
}
