layout {
    // agent templates
    pane_template name="planner" {
        pane command="opencode" {
            args  "--agent" "planner"
        }
    }
    pane_template name="manager" {
        pane command="opencode" {
            args "--agent" "manager"
        }
    }
    pane_template name="coder" {
        pane command="opencode" {
            args "--agent" "coder"
        }
    }
    pane_template name="review" {
        pane command="opencode" {
            args "--agent" "reviewer"
        }
    }

    // actual layout
    pane split_direction="Vertical" {
        manager name="manager" size="25%"
        planner name="planner" size="50%"
        pane name="terminal" size="25%"
    }

    pane size=1 borderless=true {
        plugin location="zjstatus" {
            // Rosé Pine Moon palette
            // https://rosepinetheme.com/palette/
            color_base    "#232136"
            color_surface "#2a273f"
            color_overlay "#393552"
            color_muted   "#6e6a86"
            color_subtle  "#908caa"
            color_text    "#e0def4"
            color_love    "#eb6f92"
            color_gold    "#f6c177"
            color_rose    "#ea9a97"
            color_pine    "#3e8fb0"
            color_foam    "#9ccfd8"
            color_iris    "#c4a7e7"

            format_left   "{mode}#[bg=$overlay,fg=$text] {session} #[fg=$overlay,bg=$base]{pipe_zjstatus_hints}#[bg=$base] {tabs}"
            format_center ""
            format_right  "#[fg=$overlay,bg=$base]#[bg=$overlay,fg=$subtle] {datetime}#[fg=$pine,bg=$overlay]#[bg=$pine,fg=$base,bold]  "
            format_space  "#[bg=$base]"

            hide_frame_for_single_pane "false"

            // -- mode: lualine section A (powerline arrows) --
            mode_normal        "#[bg=$pine,fg=$base,bold]  NORMAL #[fg=$pine,bg=$overlay]"
            mode_locked        "#[bg=$muted,fg=$base,bold]  LOCKED #[fg=$muted,bg=$overlay]"
            mode_pane          "#[bg=$iris,fg=$base,bold]  PANE #[fg=$iris,bg=$overlay]"
            mode_tab           "#[bg=$gold,fg=$base,bold] 󰓩 TAB #[fg=$gold,bg=$overlay]"
            mode_resize        "#[bg=$foam,fg=$base,bold]  RESIZE #[fg=$foam,bg=$overlay]"
            mode_move          "#[bg=$foam,fg=$base,bold]  MOVE #[fg=$foam,bg=$overlay]"
            mode_scroll        "#[bg=$pine,fg=$base,bold]  SCROLL #[fg=$pine,bg=$overlay]"
            mode_search        "#[bg=$gold,fg=$base,bold]  SEARCH #[fg=$gold,bg=$overlay]"
            mode_enter_search  "#[bg=$gold,fg=$base,bold]  SEARCH #[fg=$gold,bg=$overlay]"
            mode_session       "#[bg=$love,fg=$base,bold]  SESSION #[fg=$love,bg=$overlay]"
            mode_rename_tab    "#[bg=$gold,fg=$base,bold] 󰑕 RENAME TAB #[fg=$gold,bg=$overlay]"
            mode_rename_pane   "#[bg=$iris,fg=$base,bold] 󰑕 RENAME PANE #[fg=$iris,bg=$overlay]"
            mode_tmux          "#[bg=$rose,fg=$base,bold]  TMUX #[fg=$rose,bg=$overlay]"

            // -- tabs: lualine section C style --
            tab_normal              "#[fg=$base,bg=$surface]#[bg=$surface,fg=$subtle] {index}  {name} #[fg=$surface,bg=$base]"
            tab_normal_fullscreen   "#[fg=$base,bg=$surface]#[bg=$surface,fg=$subtle] {index}  {name} 󰊓 #[fg=$surface,bg=$base]"
            tab_normal_sync         "#[fg=$base,bg=$surface]#[bg=$surface,fg=$subtle] {index}  {name}  #[fg=$surface,bg=$base]"
            tab_active              "#[fg=$base,bg=$pine]#[bg=$pine,fg=$base,bold] {index}  {name} #[fg=$pine,bg=$base]"
            tab_active_fullscreen   "#[fg=$base,bg=$pine]#[bg=$pine,fg=$base,bold] {index}  {name} 󰊓 #[fg=$pine,bg=$base]"
            tab_active_sync         "#[fg=$base,bg=$pine]#[bg=$pine,fg=$base,bold] {index}  {name}  #[fg=$pine,bg=$base]"
            tab_separator           "#[bg=$base] "

            pipe_zjstatus_hints_format "{output}"

            // -- datetime: lualine section Y/Z style --
            datetime          "{format}"
            datetime_format   "%H:%M"
            datetime_timezone "America/Chicago"
        }
    }
}
